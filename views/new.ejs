<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create chat</title>
  <link rel="stylesheet" href="/new.css">
</head>
<body>
  <div id="form">
  <h3 id="head">start new chat...</h3>
  <form action="/chats" method="post">
    <label for="from ">name:</label>
<input type="text" id="from" name="from" placeholder="who are you..">

<br>
<label for="msg">Entre the msg :</label>
<br>
<textarea name="msg" id="msg">how are you</textarea>
<br>
<label for="to">send :</label>
<input type="text" id="to" name="to" placeholder="sender name">
<br>
<button type="submit">sumbit</button>
  </form>
  </div>
</body>
</html>